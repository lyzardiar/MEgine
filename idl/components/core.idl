component Name {
  value: string
}

component Transform {
  position: float3 = [0, 0, 0]
  rotation: float4 = [0, 0, 0, 1]
  scale:    float3 = [1, 1, 1]
}

component Transform2D {
  position: float2 = [0, 0]
  rotation: float  = 0
  scale:    float2 = [1, 1]
}

component Camera3D {
  fov_y_degrees:     float  = 60
  near:              float  = 0.1
  far:               float  = 1000
  primary:           bool   = true
  /// "perspective" | "orthographic"
  projection:        string = "perspective"
  orthographic_size: float  = 5
  aspect:            float  = 1.777778
  /// "scene" preserves the scene clear/environment contract; "skybox" forces the
  /// EnvironmentLight background; "solid_color" uses background_color.
  clear_flags:       string = "scene"
  background_color:  float4 = [0.1, 0.1, 0.14, 1]
}

component DirectionalLight {
  color:              float4 = [1, 1, 0.95, 1]
  intensity:          float  = 1
  cast_shadows:       bool   = true
  shadow_strength:    float  = 1
  shadow_bias:        float  = 0.0015
  shadow_normal_bias: float  = 0.02
  shadow_distance:    float  = 30
}

/// Scene-wide analytic or image-based environment lighting. The first active instance is used.
component EnvironmentLight {
  sky_color:          float4 = [0.18, 0.28, 0.5, 1]
  equator_color:      float4 = [0.12, 0.14, 0.18, 1]
  ground_color:       float4 = [0.035, 0.04, 0.05, 1]
  diffuse_intensity:  float  = 1
  specular_intensity: float  = 1
  texture:            string = ""
  rotation_degrees:   float  = 0
  /// Draw the analytic gradient or source environment map behind the scene.
  background_enabled:   bool  = true
  background_intensity: float = 1
  /// Photographic exposure compensation in stops (EV).
  exposure:           float  = 0
}

component PointLight {
  color:     float4 = [1, 1, 1, 1]
  intensity: float  = 8
  range:     float  = 10
}

component SpotLight {
  color:               float4 = [1, 1, 1, 1]
  intensity:           float  = 12
  range:               float  = 12
  inner_angle_degrees: float  = 25
  outer_angle_degrees: float  = 40
}

/// Unity-inspired 2D light. Active lights modulate world-space 2D renderers.
component Light2D {
  /// "global" | "point"
  light_type:     string       = "point"
  color:          float4       = [1, 1, 1, 1]
  intensity:      float        = 1
  radius:         float        = 5
  inner_radius:   float        = 0
  falloff:        float        = 1
  /// Empty means every project sorting layer.
  sorting_layers: string_array = []
}

component Camera2D {
  size:             float  = 5
  primary:          bool   = true
  /// "scene" | "skybox" | "solid_color". Scene keeps old serialized behavior.
  clear_flags:      string = "scene"
  background_color: float4 = [0.1, 0.1, 0.14, 1]
}

component MeshRenderer {
  mesh:            string = "cube"
  material:        string = "default"
  cast_shadows:    bool   = true
  receive_shadows: bool   = true
}

/// Per-renderer physically based material override.
component PbrMaterial {
  base_color:        float4 = [0.8, 0.8, 0.8, 1]
  metallic:          float  = 0
  roughness:         float  = 0.5
  ior:               float  = 1.5
  emissive:          float3 = [0, 0, 0]
  emissive_strength: float  = 1
  unlit:             bool   = false
  double_sided:      bool   = false
}

/// Per-renderer parameter overrides applied after the material asset is resolved.
/// Unlike PbrMaterial, this preserves textures, shader, surface, and pipeline state.
component MaterialPropertyBlock {
  override_base_color:        bool   = false
  base_color:                 float4 = [1, 1, 1, 1]
  override_metallic:          bool   = false
  metallic:                   float  = 0
  override_roughness:         bool   = false
  roughness:                  float  = 0.5
  override_ior:               bool   = false
  ior:                        float  = 1.5
  override_clearcoat:         bool   = false
  clearcoat:                  float  = 0
  override_clearcoat_roughness: bool = false
  clearcoat_roughness:        float  = 0.1
  override_emissive:          bool   = false
  emissive:                   float3 = [0, 0, 0]
  override_emissive_strength: bool   = false
  emissive_strength:          float  = 1
}

component SpriteRenderer {
  sprite: string = "white"
  color:  float4 = [1, 1, 1, 1]
  /// World-space quad size (meters-ish)
  size:   float2 = [1, 1]
  /// Normalized transform origin in sprite space (bottom-left = [0, 0])
  pivot:  float2 = [0.5, 0.5]
  /// Mirror texture coordinates without changing Transform scale
  flip_x: bool = false
  flip_y: bool = false
  /// Stable id from ProjectSettings/sorting-layers.json
  sorting_layer: string = "default"
  /// Draw order among world sprites (higher = closer / later)
  sorting_order: int = 0
}

/// Godot-style world-space animated sprite using an ordered texture frame list.
component AnimatedSprite2D {
  frames:        string_array = []
  fps:           float        = 12
  playing:       bool         = true
  looped:        bool         = true
  frame:         int          = 0
  color:         float4       = [1, 1, 1, 1]
  size:          float2       = [1, 1]
  pivot:         float2       = [0.5, 0.5]
  flip_x:        bool         = false
  flip_y:        bool         = false
  sorting_layer: string       = "default"
  sorting_order: int          = 0
}

/// Godot-style world-space polyline.
component Line2D {
  points:        float2_array = []
  width:         float        = 0.1
  color:         float4       = [1, 1, 1, 1]
  closed:        bool         = false
  sorting_layer: string       = "default"
  sorting_order: int          = 0
}

/// Unity-style parent grid used by Tilemap children.
component Grid {
  cell_size:   float2 = [1, 1]
  cell_gap:    float2 = [0, 0]
  cell_layout: string = "Rectangle"
}

/// Sparse world-space tile layer. cells and sprites are parallel arrays.
component Tilemap {
  cells:         float2_array  = []
  sprites:       string_array  = []
  color:         float4        = [1, 1, 1, 1]
  tile_anchor:   float2        = [0.5, 0.5]
  sorting_layer: string        = "default"
  sorting_order: int           = 0
}

/// Plays a versioned .manim AnimationClip on this entity hierarchy.
component AnimationPlayer {
  clip:          string = ""
  play_on_awake: bool   = true
  playing:       bool   = true
  speed:         float  = 1
  time:          float  = 0
}

/// Plays a state-machine .mcontroller asset with parameters and cross-fade transitions.
component Animator {
  controller:      string = ""
  play_on_awake:   bool   = true
  playing:         bool   = true
  speed:           float  = 1
  current_state:   string = ""
  parameters_json: string = "{}"
  layer_weights_json: string = "{}"
  layers_json:        string = "{}"
  state_time:          float  = 0
  normalized_time:     float  = 0
  transition_to:       string = ""
  transition_progress: float  = 0
}

/// Plays a versioned .mtimeline Sequencer asset and emits its track events.
component TimelineDirector {
  asset:         string = ""
  /// Versioned JSON map from Timeline target paths to stable scene entity ids.
  bindings_json: string = "{}"
  play_on_awake: bool   = true
  playing:       bool   = true
  speed:         float  = 1
  time:          float  = 0
  wrap_mode:     string = "Hold"
}

/// Spatial audio listener. The first active primary listener wins.
component AudioListener {
  primary: bool = true
}

/// Playable audio emitter. clip is a project-relative WAV, OGG, MP3, or FLAC asset.
component AudioSource {
  clip:             string = ""
  play_on_awake:    bool   = true
  playing:          bool   = true
  time:             float  = 0
  looped:           bool   = false
  volume:           float  = 1
  pitch:            float  = 1
  pan:              float  = 0
  spatial_blend:    float  = 0
  min_distance:     float  = 1
  max_distance:     float  = 100
  bus:              string = "SFX"
  mute:             bool   = false
}

/// Scene-level master and category mixer. The first active component wins.
component AudioMixer {
  master_volume:   float = 1
  music_volume:    float = 1
  sfx_volume:      float = 1
  ui_volume:       float = 1
  ambience_volume: float = 1
  muted:           bool  = false
}

/// 3D rigid-body simulation settings. body_type: "dynamic" | "fixed" | "kinematic".
component RigidBody3D {
  body_type:        string = "dynamic"
  mass:             float  = 1
  gravity_scale:    float  = 1
  linear_damping:   float  = 0.05
  angular_damping:  float  = 0.05
  velocity:         float3 = [0, 0, 0]
  angular_velocity: float3 = [0, 0, 0]
  lock_rotation:    bool   = false
  ccd:              bool   = false
}

/// Axis-aligned local box shape attached to this entity's RigidBody3D.
component BoxCollider3D {
  size:        float3 = [1, 1, 1]
  center:      float3 = [0, 0, 0]
  is_trigger:  bool   = false
  friction:    float  = 0.5
  restitution: float  = 0
}

/// Local sphere shape attached to this entity's RigidBody3D.
component SphereCollider3D {
  radius:      float  = 0.5
  center:      float3 = [0, 0, 0]
  is_trigger:  bool   = false
  friction:    float  = 0.5
  restitution: float  = 0
}

/// Unity-style planar rigid body simulated by Rapier2D. angular_velocity is degrees/second.
component Rigidbody2D {
  /// "dynamic" | "fixed" | "kinematic"
  body_type:        string = "dynamic"
  mass:             float  = 1
  gravity_scale:    float  = 1
  linear_damping:   float  = 0.05
  angular_damping:  float  = 0.05
  velocity:         float2 = [0, 0]
  angular_velocity: float  = 0
  freeze_rotation:  bool   = false
  ccd:              bool   = false
}

/// Local 2D box collision or trigger shape. A collider without Rigidbody2D is fixed.
component BoxCollider2D {
  size:        float2 = [1, 1]
  offset:      float2 = [0, 0]
  is_trigger:  bool   = false
  friction:    float  = 0.5
  bounciness:  float  = 0
}

/// Local 2D circle collision or trigger shape. A collider without Rigidbody2D is fixed.
component CircleCollider2D {
  radius:      float  = 0.5
  offset:      float2 = [0, 0]
  is_trigger:  bool   = false
  friction:    float  = 0.5
  bounciness:  float  = 0
}

component Layer {
  value: int = 0
}

component EditorOnly {
}

/// Continuous spin around an axis. angle = deg/s base, speed = multiplier.
component AutoRotate {
  axis:  float3 = [0, 1, 0]
  angle: float  = 90
  speed: float  = 1
}

/// Deterministic XY particle emitter rendered in world space.
component ParticleEmitter2D {
  playing:          bool   = true
  looping:          bool   = true
  duration:         float  = 5
  start_delay:      float  = 0
  rate_over_time:   float  = 20
  max_particles:    int    = 1000
  lifetime_min:     float  = 0.8
  lifetime_max:     float  = 1.6
  speed_min:        float  = 0.5
  speed_max:        float  = 2
  size_start:       float  = 0.18
  size_end:         float  = 0
  color_start:      float4 = [1, 0.75, 0.2, 1]
  color_end:        float4 = [1, 0.15, 0.02, 0]
  gravity:          float2 = [0, -0.8]
  shape:            string = "circle"
  shape_radius:     float  = 0.2
  shape_size:       float2 = [1, 1]
  direction:        float2 = [0, 1]
  spread_degrees:   float  = 35
  simulation_space: string = "world"
  blend_mode:       string = "additive"
  texture:          string = ""
  sorting_layer:    string = "default"
  sorting_order:    int    = 0
  seed:             int    = 1
}

/// Deterministic XYZ particle emitter rendered as camera-facing billboards.
component ParticleEmitter3D {
  playing:          bool   = true
  looping:          bool   = true
  duration:         float  = 5
  start_delay:      float  = 0
  rate_over_time:   float  = 30
  max_particles:    int    = 2000
  lifetime_min:     float  = 1
  lifetime_max:     float  = 2
  speed_min:        float  = 0.8
  speed_max:        float  = 3
  size_start:       float  = 0.16
  size_end:         float  = 0.02
  color_start:      float4 = [0.35, 0.75, 1, 1]
  color_end:        float4 = [0.05, 0.2, 1, 0]
  gravity:          float3 = [0, -0.6, 0]
  shape:            string = "cone"
  shape_radius:     float  = 0.25
  shape_size:       float3 = [1, 1, 1]
  direction:        float3 = [0, 1, 0]
  spread_degrees:   float  = 25
  simulation_space: string = "world"
  blend_mode:       string = "additive"
  texture:          string = ""
  billboard:        bool   = true
  seed:             int    = 1
}

/// Spine 4.3 skeleton instance. Skeleton and atlas paths are project-relative assets.
component SpineSkeleton {
  skeleton:             string = ""
  atlas:                string = ""
  animation:            string = ""
  skin:                 string = "default"
  loop_animation:       bool   = true
  playing:              bool   = true
  time_scale:           float  = 1
  scale:                float  = 1
  color:                float4 = [1, 1, 1, 1]
  premultiplied_alpha:  bool   = true
  sorting_layer:        string = "default"
  sorting_order:        int    = 0
}
