{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MEngine Editor",
  "version": "0.1.0",
  "identifier": "com.mengine.editor",
  "build": {
    "beforeDevCommand": "pnpm --filter @mengine/editor dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter @mengine/editor build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MEngine Editor",
        "width": 1440,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
